{
	"$schema": "https://schema.tauri.app/config/2",
	"app": {
		"security": {
			"csp": null
		},
		"windows": [
			{
				"fullscreen": false,
				"height": 900,
				"resizable": true,
				"title": "tend",
				"width": 1400
			}
		]
	},
	"build": {
		"beforeBuildCommand": "pnpm build",
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"frontendDist": "../dist"
	},
	"bundle": {
		"active": true,
		"icon": ["icons/icon.png"],
		"targets": "all"
	},
	"identifier": "io.knitli.tend",
	"plugins": {
		"notification": {}
	},
	"productName": "tend",
	"version": "0.1.0"
}
